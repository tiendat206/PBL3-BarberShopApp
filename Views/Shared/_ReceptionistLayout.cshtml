<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Thu ngân - BarberMate</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --pos-bg: #f4f6f9; --accent: #ff9d00; }
        body { background-color: var(--pos-bg); font-family: 'Segoe UI', sans-serif; height: 100vh; overflow: hidden; }
        .navbar-barber { background: #1a1a1a; color: white; }
        .main-pos-container { height: calc(100vh - 56px); display: flex; }
        .menu-section { flex: 7; padding: 20px; overflow-y: auto; }
        .bill-section { flex: 3; background: white; border-left: 1px solid #ddd; display: flex; flex-direction: column; }
        
        .service-card { cursor: pointer; transition: 0.2s; border: none; border-radius: 10px; }
        .service-card:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); border: 1px solid var(--accent); }
        .category-pill { cursor: pointer; padding: 8px 20px; border-radius: 20px; background: white; margin-right: 10px; border: 1px solid #ddd; }
        .category-pill.active { background: var(--accent); color: white; border-color: var(--accent); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark navbar-barber px-4">
        <a class="navbar-brand" href="#">BARBER<b>MATE</b> <span class="badge bg-warning text-dark ms-2" style="font-size: 10px;">LỄ TÂN</span></a>
        <div class="navbar-nav ms-auto">
            <a class="nav-link active" href="#"><i class="bi bi-cart3"></i> Thu ngân</a>
            <a class="nav-link" href="#"><i class="bi bi-calendar-event"></i> Lịch hẹn</a>
            <a class="nav-link" href="#"><i class="bi bi-person-badge"></i> Khách hàng</a>
            <a class="nav-link text-danger" href="/"><i class="bi bi-power"></i></a>
        </div>
    </nav>

    <div class="main-pos-container">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>