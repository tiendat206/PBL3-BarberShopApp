@model BarberShopApp.Models.LoginViewModel
@{ Layout = null; }

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BarberMate - Find Your Perfect Haircut</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-gold: #ff9d00;
            --dark-bg: #121212;
            --text-gray: #888;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background-color: var(--dark-bg);
            color: white;
            overflow: hidden; /* Ngăn cuộn trang khi form bay vào */
        }

        /* --- LANDING PAGE --- */
        #landing-page {
            height: 100vh;
            width: 100%;
            transition: all 0.8s cubic-bezier(0.77, 0, 0.175, 1);
            background: linear-gradient(to bottom, rgba(18,18,18,0.8), rgba(18,18,18,0.95)), 
                        url('https://images.unsplash.com/photo-1585747860715-2ba37e788b70?q=80&w=2074&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
        }

        header { display: flex; justify-content: space-between; align-items: center; padding: 30px 60px; }
        .logo { font-family: 'Playfair Display', serif; font-size: 1.8rem; border-bottom: 2px solid var(--primary-gold); cursor: pointer;}
        .logo span { color: var(--primary-gold); }

        .btn-gold { 
            background: var(--primary-gold); color: black; font-weight: 600; 
            padding: 12px 30px; border: none; border-radius: 30px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        }
        .btn-gold:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(255,157,0,0.4); }

        .hero-section { padding: 100px 60px; }
        .hero-title { font-family: 'Playfair Display', serif; font-size: 5rem; line-height: 1.1; margin-bottom: 20px; text-transform: uppercase; }
        .hero-title span { border-bottom: 5px solid var(--primary-gold); }

        /* --- 4. Cải thiện Background Overlay (Gradient mượt hơn) --- */
        #login-overlay { 
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%; 
            display: flex; transition: right 0.6s ease-in-out; z-index: 1000; 
        }
        #login-overlay.active { right: 0; }
        
        .login-left-img { 
            flex: 1.2; 
            background: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.7) 100%),
                        url('https://images.unsplash.com/photo-1503951914875-452162b0f3f1?q=80&w=2070&auto=format&fit=crop') center/cover;
        }
        
        .login-right-form { 
            flex: 1; background: white; color: black; 
            display: flex; flex-direction: column; justify-content: center; 
            padding: 60px; position: relative; 
            box-shadow: -10px 0 30px rgba(0,0,0,0.2);
        }
        
        .close-login { 
            position: absolute; top: 30px; right: 40px; font-size: 2rem; 
            cursor: pointer; color: var(--text-gray); transition: 0.3s;
        }
        .close-login:hover { color: black; transform: rotate(90deg); }
        
        .brand-philly { font-family: 'Playfair Display', serif; font-size: 3rem; text-align: center; margin-bottom: 10px; }

        /* --- 2. Cải thiện Toggle (Glassmorphism & Elastic) --- */
        .role-toggle { 
            position: relative; width: 100%; height: 50px; 
            background-color: rgba(0,0,0,0.05); /* Glassmorphism nhẹ */
            border-radius: 30px; display: flex; margin: 20px 0 30px 0; 
            overflow: hidden; border: 1px solid rgba(0,0,0,0.1);
        }
        .toggle-bg { 
            position: absolute; top: 3px; left: 3px; width: calc(50% - 6px); height: calc(100% - 6px); 
            background-color: #1a1a1a; border-radius: 30px; 
            /* Hiệu ứng nảy Elastic */
            transition: transform 0.5s cubic-bezier(0.68, -0.55, 0.27, 1.55); 
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        }
        .toggle-btn { 
            flex: 1; border: none; background: transparent; 
            font-size: 15px; font-weight: 600; color: #1a1a1a; 
            cursor: pointer; position: relative; z-index: 1; transition: color 0.3s ease; 
        }
        .toggle-btn.active-text { color: #fff; }

        /* --- 3. Cải thiện Input Fields (Floating Labels & Icons) --- */
        .form-group-custom { position: relative; margin-bottom: 25px; }
        
        .form-group-custom i {
            position: absolute; left: 15px; top: 50%; transform: translateY(-50%);
            color: var(--text-gray); font-size: 1.1rem; transition: 0.3s;
        }

        .form-control-custom { 
            border: 1px solid #ddd; border-radius: 30px;
            padding: 15px 15px 15px 50px; /* Thêm padding bên trái cho icon */
            width: 100%; transition: 0.3s; font-size: 1rem;
        }
        .form-control-custom:focus { 
            outline: none; border-color: var(--primary-gold); 
            box-shadow: 0 5px 15px rgba(255,157,0,0.1); 
        }
        
        /* Floating Label Logic */
        .floating-label {
            position: absolute; left: 50px; top: 50%; transform: translateY(-50%);
            color: var(--text-gray); pointer-events: none; transition: 0.3s;
            background-color: white; padding: 0 5px;
        }
        
        .form-control-custom:focus + .floating-label,
        .form-control-custom:not(:placeholder-shown) + .floating-label {
            top: 0; font-size: 0.85rem; color: var(--primary-gold);
        }
        
        .form-control-custom:focus ~ i { color: var(--primary-gold); }

        /* --- 5. Thêm Loading State cho nút --- */
        .btn-dark-login { 
            background: linear-gradient(45deg, #1a1a1a, #333); 
            color: white; width: 100%; padding: 16px; border-radius: 30px;
            margin-top: 10px; letter-spacing: 2px; border: none; font-weight: bold; 
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative; display: flex; justify-content: center; align-items: center;
        }
        .btn-dark-login:hover { 
            background: #000; transform: scale(1.03); 
            box-shadow: 0 10px 25px rgba(0,0,0,0.3); 
        }
        
        /* Spinner ẩn mặc định */
        .spinner-border-custom {
            display: none; width: 1rem; height: 1rem;
            border: 2px solid currentColor; border-right-color: transparent;
            border-radius: 50%; animation: spinner-border .75s linear infinite;
            margin-right: 10px;
        }
        @@keyframes spinner-border { to { transform: rotate(360deg); } }
        
        /* Khi nút ở trạng thái loading */
        .btn-dark-login.loading .spinner-border-custom { display: inline-block; }
        .btn-dark-login.loading .btn-text { opacity: 0.7; }

        .extra-links { text-align: center; margin-top: 20px; font-size: 14px; }
        .extra-links a { color: var(--primary-gold); text-decoration: none; font-weight: 600; cursor: pointer; transition: 0.3s;}
        .extra-links a:hover { text-decoration: underline; color: #cc7a00; }

        .validation-summary-errors { 
            background: #fff5f5; color: #d9534f; padding: 15px; 
            border-radius: 10px; border: 1px solid #ebccd1; 
            font-size: 0.9rem; margin-bottom: 20px; list-style: none; 
            box-shadow: 0 5px 10px rgba(217,83,79,0.1);
        }
        .validation-summary-errors ul { margin: 0; padding: 0; list-style: none; }
    </style>
</head>
<body>
    <div id="landing-page">
        <header>
            <div class="logo">BarberShop<span>System</span></div>
            <button class="btn-gold" onclick="showLogin()">Log In</button>
        </header>

        <main class="hero-section">
            <h1 class="hero-title animate__animated animate__fadeInUp">Modern Barbershop<br><span>Managerment Platform</span></h1>
            <p class="mt-4 w-50 text-secondary animate__animated animate__fadeInUp animate__delay-1s">Hệ thống quản lý Barber chuyên nghiệp. Đặt lịch, thanh toán và quản lý nhân viên.</p>
            <button class="btn btn-outline-gold mt-4 animate__animated animate__fadeInUp animate__delay-1s" onclick="showLogin()">Get Started →</button>
        </main>
    </div>

    <div id="login-overlay">
        <div class="login-left-img"></div>

        <div class="login-right-form animate__animated animate__fadeInRight">
            <span class="close-login" onclick="hideLogin()">&times;</span>

            <h1 class="brand-philly">BARBERSHOP</h1>
            <p class="text-center text-muted mb-4">Trải nghiệm phong cách quý ông đích thực</p>

            <div class="role-toggle" id="role-toggle-container">
                <div class="toggle-bg" id="toggle-bg"></div>
                <button type="button" class="toggle-btn active-text" id="btn-staff" onclick="switchRole('staff')">
                    <i class="fa-solid fa-user-tie me-2"></i>Quản lý / Lễ tân
                </button>
                <button type="button" class="toggle-btn" id="btn-customer" onclick="switchRole('customer')">
                    <i class="fa-solid fa-user me-2"></i>Khách hàng
                </button>
            </div>

            <div id="form-login-container">
                <form asp-action="Login" method="post" autocomplete="off" onsubmit="setLoading(this)">
                    <div asp-validation-summary="All" class="text-danger"></div>
                    <input type="hidden" asp-for="LoginType" id="login-type-input" value="staff" />

                    <div class="form-group-custom">
                        <i class="fa-solid fa-circle-user"></i>
                        <input asp-for="Username" id="username-input" class="form-control-custom" placeholder=" " autocomplete="off" />
                        <label class="floating-label" id="username-label">Username</label>
                    </div>

                    <div class="form-group-custom">
                        <i class="fa-solid fa-lock"></i>
                        <input asp-for="Password" type="password" class="form-control-custom" placeholder=" " autocomplete="new-password" />
                        <label class="floating-label">Password</label>
                    </div>

                    <button type="submit" class="btn-dark-login" id="btn-login-submit">
                        <span class="spinner-border-custom"></span>
                        <span class="btn-text">LOG IN</span>
                    </button>

                    <div class="extra-links" id="customer-links" style="display: none;">
                        <a onclick="toggleMode('register')">Chưa có tài khoản? Đăng ký ngay</a>
                    </div>
                </form>
            </div>

            <div id="form-register-container" style="display: none;">
                <form asp-controller="Account" asp-action="Register" method="post" autocomplete="off">
                    <h5 class="text-center mb-4" style="font-weight: 600;">ĐĂNG KÝ THÀNH VIÊN</h5>
                    
                    <div class="form-group-custom">
                        <i class="fa-solid fa-id-card"></i>
                       <input type="text" name="Username" class="form-control-custom" placeholder="Tên đăng nhập" autocomplete="new-username" required />
                    </div>
                    
                    <div class="form-group-custom">
                        <i class="fa-solid fa-signature"></i>
                        <input type="text" name="FullName" class="form-control-custom" placeholder="Họ và tên" required />
                    </div>
                    
                    <div class="form-group-custom">
                        <i class="fa-solid fa-phone"></i>
                        <input type="tel" name="Phone" class="form-control-custom" placeholder="Số điện thoại" required />
                    </div>
                    
                    <div class="form-group-custom">
                        <i class="fa-solid fa-lock"></i>
                       <input type="password" name="Password" class="form-control-custom" placeholder="Mật khẩu" autocomplete="new-password" required />
                    </div>
                    
                    <button type="submit" class="btn-dark-login">TẠO TÀI KHOẢN</button>

                    <div class="extra-links">
                        <a onclick="toggleMode('login')">Đã có tài khoản? Quay lại đăng nhập</a>
                    </div>
                </form>
            </div>

            <p class="text-center mt-5 small text-muted">&copy; BarberManagerment System</p>
        </div>
    </div>

    <script>
        function showLogin() {
            document.getElementById('login-overlay').classList.add('active');
            document.getElementById('landing-page').style.transform = 'scale(0.9)';
            document.getElementById('landing-page').style.filter = 'blur(5px)';
        }

        function hideLogin() {
            document.getElementById('login-overlay').classList.remove('active');
            document.getElementById('landing-page').style.transform = 'scale(1)';
            document.getElementById('landing-page').style.filter = 'none';
            toggleMode('login');
        }

        function switchRole(role) {
            const bg = document.getElementById('toggle-bg');
            const btnStaff = document.getElementById('btn-staff');
            const btnCustomer = document.getElementById('btn-customer');
            const usernameLabel = document.getElementById('username-label');
            const customerLinks = document.getElementById('customer-links');
            const loginTypeInput = document.getElementById('login-type-input');

            if (role === 'staff') {
                bg.style.transform = 'translateX(0)';
                btnStaff.classList.add('active-text');
                btnCustomer.classList.remove('active-text');
                
                usernameLabel.innerText = 'Username';
                customerLinks.style.display = 'none';
                loginTypeInput.value = 'staff';
            } else {
                bg.style.transform = 'translateX(100%)';
                btnStaff.classList.remove('active-text');
                btnCustomer.classList.add('active-text');
                
                usernameLabel.innerText = 'Số điện thoại / Username';
                customerLinks.style.display = 'block';
                loginTypeInput.value = 'customer';
            }
        }

        function toggleMode(mode) {
            const loginContainer = document.getElementById('form-login-container');
            const registerContainer = document.getElementById('form-register-container');
            const roleToggle = document.getElementById('role-toggle-container');

            if (mode === 'register') {
                loginContainer.style.display = 'none';
                roleToggle.style.display = 'none';
                registerContainer.style.display = 'block';
            } else {
                registerContainer.style.display = 'none';
                roleToggle.style.display = 'flex';
                loginContainer.style.display = 'block';
                switchRole('customer');
            }
        }

        // 5. Hàm xử lý Loading State khi submit
        function setLoading(form) {
            // Kiểm tra xem form có hợp lệ (validation) không trước khi loading
            if (form.checkValidity()) {
                const btn = document.getElementById('btn-login-submit');
                btn.classList.add('loading');
                btn.disabled = true; // Ngăn người dùng nhấn nhiều lần
            }
        }

        window.onload = function() {
            var errorDiv = document.querySelector(".validation-summary-errors");
            if (errorDiv && errorDiv.innerText.trim() !== "") {
                showLogin();
                var currentType = document.getElementById('login-type-input').value;
                switchRole(currentType || 'staff'); 
            } else {
                hideLogin();
                switchRole('staff'); 
            }
        };
    </script>
</body>
</html>