@{
    Layout = "_ReceptionistLayout";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    /* CSS tinh chỉnh UI/UX */
    .service-card { transition: all 0.2s ease; cursor: pointer; border: 1px solid #eee; }
    .service-card:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important; border-color: var(--primary-gold, #ff9d00); }
    .bill-section { background-color: #fafafa !important; border-left: 1px solid #e0e0e0 !important; }
    .table-hover tbody tr:hover { background-color: #f8f9fa; cursor: pointer; }
    .category-pill { cursor: pointer; padding: 8px 20px; border-radius: 20px; font-weight: 500; color: #555; transition: 0.3s; margin-right: 10px; background: #f0f0f0; }
    .category-pill.active { background: #1a1a1a; color: white; box-shadow: 0 4px 10px rgba(0,0,0,0.15); }
    .category-pill:hover:not(.active) { background: #e0e0e0; }
    
    .tab-pane { transition: opacity 0.3s ease-in-out; }

    /* Nút xóa sản phẩm nổi bật hơn */
    .btn-delete-item { color: #dc3545; background: transparent; border: none; padding: 5px; transition: 0.2s; border-radius: 5px; display: flex; align-items: center; justify-content: center;}
    .btn-delete-item:hover { background: #ffe6e6; color: #b91c1c; transform: scale(1.1); }
</style>

<div class="tab-content h-100" id="receptionistTabContent">

    <div class="tab-pane fade show active h-100" id="tab-thungan" role="tabpanel">
        <div class="row m-0 h-100 bg-white">
            
            <div class="col-lg-7 col-md-6 menu-section p-4" style="overflow-y: auto;">
                <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                    <div class="d-flex flex-wrap gap-2">
                        <div class="category-pill active m-0">Tất cả</div>
                        <div class="category-pill m-0">Dịch vụ (Cắt/Gội)</div>
                        <div class="category-pill m-0">Sản phẩm (Sáp/Gôm)</div>
                    </div>
                    <div class="ms-auto position-relative" style="width: 250px;">
                        <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 15px; top: 50%; transform: translateY(-50%);"></i>
                        <input type="text" class="form-control rounded-pill ps-5 bg-light" placeholder="Tìm theo tên...">
                    </div>
                </div>

                <div class="row g-3">
                    @for (int i = 1; i <= 8; i++)
                    {
                        <div class="col-xl-3 col-lg-4 col-sm-6">
                            <div class="card service-card h-100 p-2 text-center shadow-sm rounded-4">
                                <img src="https://via.placeholder.com/200x120?text=Combo+Barber" class="card-img-top rounded-3" style="object-fit: cover; height: 120px;">
                                <div class="card-body p-2 d-flex flex-column justify-content-between">
                                    <h6 class="mb-2 fw-bold text-dark text-truncate" title="Combo Cắt Gội @i">Combo Cắt Gội @i</h6>
                                    <p class="text-success fw-bold mb-0 fs-5 text-nowrap">100.000đ</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-5 col-md-6 bill-section p-4 d-flex flex-column shadow-lg z-1 h-100">
                <h5 class="fw-bold mb-4 d-flex justify-content-between align-items-center">
                    <span><i class="fa-solid fa-file-invoice-dollar text-warning me-2"></i>Hóa đơn hiện tại</span>
                    
                    <button class="btn btn-sm btn-outline-secondary rounded-circle d-flex align-items-center justify-content-center bg-white shadow-sm" style="width: 35px; height: 35px;" title="Làm mới hóa đơn">
                        <i class="fa-solid fa-rotate-right fs-5 text-dark"></i>
                    </button>
                </h5>
                
                <div class="card border-0 shadow-sm rounded-3 mb-3">
                    <div class="card-body p-3">
                        <div class="mb-3">
                            <label class="small text-muted mb-2 fw-bold">Thông tin khách hàng</label>
                            <div class="input-group input-group-sm mb-2">
                                <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-user"></i></span>
                                <input type="text" class="form-control bg-light border-start-0 ps-0" placeholder="Họ và tên khách hàng...">
                            </div>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-phone"></i></span>
                                <input type="tel" class="form-control bg-light border-start-0 ps-0" placeholder="Số điện thoại...">
                            </div>
                        </div>
                        
                        <div>
                            <label class="small text-muted mb-1 fw-bold">Thợ thực hiện (Barber)</label>
                            <select class="form-select form-select-sm bg-light fw-bold text-primary">
                                <option selected>-- Chọn Barber --</option>
                                <option>Anh Tú (Đang rảnh)</option>
                                <option disabled>Trọng Nghĩa (Đang bận)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="flex-grow-1 overflow-auto bg-white border rounded-3 p-2 mb-3 shadow-sm">
                    <table class="table table-borderless table-sm mb-0 align-middle">
                        <thead class="border-bottom">
                            <tr class="small text-muted">
                                <th>Dịch vụ/Sản phẩm</th>
                                <th class="text-center" style="width: 60px;">SL</th>
                                <th class="text-end" style="width: 80px;">Giá</th>
                                <th style="width: 45px;"></th> </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><div class="fw-bold text-dark">Cắt tóc nam</div><small class="text-muted">Mã: DV01</small></td>
                                <td class="text-center">
                                    <input type="number" class="form-control form-control-sm text-center px-1" value="1" min="1">
                                </td>
                                <td class="text-end fw-bold text-dark text-nowrap">100k</td>
                                <td class="text-center align-middle">
                                    <button class="btn-delete-item" title="Xóa dịch vụ">
                                        <i class="fa-solid fa-trash-can fs-5"></i>
                                    </button>
                                </td>
                            </tr>
                            <tr>
                                <td><div class="fw-bold text-dark">Sáp Volcanic Clay</div><small class="text-muted">Mã: SP05</small></td>
                                <td class="text-center">
                                    <input type="number" class="form-control form-control-sm text-center px-1" value="1" min="1">
                                </td>
                                <td class="text-end fw-bold text-dark text-nowrap">250k</td>
                                <td class="text-center align-middle">
                                    <button class="btn-delete-item" title="Xóa sản phẩm">
                                        <i class="fa-solid fa-trash-can fs-5"></i>
                                    </button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="card border-0 shadow-sm rounded-3 mt-auto">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between mb-2 small text-muted fw-bold">
                            <span>Tạm tính (2 mục):</span>
                            <span class="text-dark">350.000đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3 small text-muted fw-bold border-bottom pb-2">
                            <span>Chiết khấu/Giảm giá:</span>
                            <span class="text-danger">-0đ</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-end mb-3">
                            <span class="text-muted fw-bold">KHÁCH PHẢI TRẢ</span>
                            <span class="fs-3 fw-bold text-success" style="line-height: 1;">350.000đ</span>
                        </div>
                        <button class="btn btn-dark w-100 py-3 rounded-3 fw-bold fs-5 text-warning shadow" style="letter-spacing: 1px;">
                            <i class="fa-solid fa-money-bill-wave me-2"></i> THANH TOÁN
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade p-4 bg-light h-100" id="tab-lichhen" role="tabpanel" style="overflow-y: auto;">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-end mb-4 bg-white p-3 rounded-3 shadow-sm">
                <div>
                    <h4 class="fw-bold mb-1"><i class="fa-regular fa-calendar-days text-primary me-2"></i>Quản lý Lịch hẹn</h4>
                    <span class="text-muted small">Kiểm soát lịch khách đặt online và trực tiếp</span>
                </div>
                <div class="d-flex gap-3 align-items-center">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fa-solid fa-calendar"></i></span>
                        <input type="date" class="form-control fw-bold" value="2026-03-30">
                    </div>
                    <div class="btn-group shadow-sm">
                        <button class="btn btn-dark px-4 fw-bold">Hôm nay</button>
                        <button class="btn btn-outline-dark px-4">Ngày mai</button>
                    </div>
                    <button class="btn btn-warning fw-bold text-dark shadow-sm"><i class="fa-solid fa-plus me-1"></i> Tạo lịch mới</button>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 bg-white">
                        <thead class="table-light">
                            <tr class="text-muted small text-uppercase fw-bold">
                                <th class="ps-4 py-3">Giờ hẹn</th>
                                <th>Khách hàng</th>
                                <th>Dịch vụ yêu cầu</th>
                                <th>Barber phụ trách</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4"><span class="badge bg-dark fs-6 py-2 px-3 rounded-pill">09:00</span></td>
                                <td>
                                    <div class="fw-bold text-dark">Nguyễn Văn A</div>
                                    <small class="text-muted"><i class="fa-solid fa-phone me-1"></i>0901.234.567</small>
                                </td>
                                <td class="fw-medium text-dark">Combo Cắt Gội 1</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary rounded-circle me-2" style="width: 10px; height: 10px;"></div>
                                        Trần B
                                    </div>
                                </td>
                                <td><span class="badge bg-warning text-dark px-3 py-2 rounded-pill fw-bold"><i class="fa-regular fa-clock me-1"></i>Chờ khách</span></td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-success fw-bold rounded-pill px-3 shadow-sm me-1"><i class="fa-solid fa-check me-1"></i>Đã tới</button>
                                    <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm" title="Hủy lịch"><i class="fa-solid fa-xmark"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade p-4 bg-light h-100" id="tab-khachhang" role="tabpanel" style="overflow-y: auto;">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-end mb-4 bg-white p-3 rounded-3 shadow-sm">
                <div>
                    <h4 class="fw-bold mb-1"><i class="fa-solid fa-users text-success me-2"></i>Database Khách hàng</h4>
                    <span class="text-muted small">Quản lý thông tin và điểm tích lũy</span>
                </div>
                <div class="d-flex gap-3">
                    <div class="input-group shadow-sm" style="width: 350px;">
                        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0 fw-medium" placeholder="Tìm theo Tên, SĐT hoặc Mã KH...">
                    </div>
                    <button class="btn btn-success fw-bold shadow-sm"><i class="fa-solid fa-user-plus me-1"></i> Đăng ký KH</button>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 bg-white">
                        <thead class="table-light">
                            <tr class="text-muted small text-uppercase fw-bold">
                                <th class="ps-4 py-3">Khách hàng</th>
                                <th>Liên hệ</th>
                                <th>Hạng TV</th>
                                <th class="text-center">Điểm thưởng</th>
                                <th>Lần cuối ghé</th>
                                <th class="text-end pe-4">Tùy chọn</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">Nguyễn Tiến Đạt</div>
                                    <small class="text-muted">#KH001</small>
                                </td>
                                <td class="fw-medium text-dark"><i class="fa-solid fa-phone me-1 text-muted small"></i>0941.462.256</td>
                                <td><span class="badge bg-secondary px-3 py-2 rounded-pill">Thành viên</span></td>
                                <td class="text-center"><span class="badge bg-warning text-dark fs-6 px-3 rounded-pill shadow-sm">0</span></td>
                                <td class="text-muted small">Chưa có</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-1" title="Lịch sử cắt"><i class="fa-solid fa-clock-rotate-left"></i></button>
                                    <button class="btn btn-sm btn-light text-dark rounded-circle shadow-sm" title="Sửa thông tin"><i class="fa-solid fa-pen"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const navLinks = document.querySelectorAll('.nav-link, a');
        
        navLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                const text = this.innerText.trim();
                
                if(text.includes('Thu ngân') || text.includes('Lịch hẹn') || text.includes('Khách hàng')) {
                    e.preventDefault();
                    
                    document.querySelectorAll('.tab-pane').forEach(tab => {
                        tab.classList.remove('show', 'active');
                    });

                    navLinks.forEach(n => n.classList.remove('active', 'text-warning'));
                    if(this.classList.contains('nav-link')) {
                         this.classList.add('active', 'text-warning');
                    }

                    if(text.includes('Thu ngân')) document.getElementById('tab-thungan').classList.add('show', 'active');
                    if(text.includes('Lịch hẹn')) document.getElementById('tab-lichhen').classList.add('show', 'active');
                    if(text.includes('Khách hàng')) document.getElementById('tab-khachhang').classList.add('show', 'active');
                }
            });
        });
    });
</script>